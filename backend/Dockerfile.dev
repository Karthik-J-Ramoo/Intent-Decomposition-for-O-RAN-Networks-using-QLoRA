FROM python:3.11-slim
WORKDIR /app

# Copy only necessary backend files for quick dev/test builds
COPY backend /app/backend

RUN pip install --no-cache-dir "fastapi>=0.95.0" "uvicorn[standard]>=0.21.0"

ENV PYTHONUTF8=1
ENV PORT=8000

EXPOSE 8000
CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000", "--lifespan", "off"]
